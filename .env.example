# Proxy opcional para yt-dlp (ex.: http://user:senha@host:porta)
PROXY=
# ou
YTDLP_PROXY=

# esquema de proxy rotativo com ipv6 usando esse projeto como referencia https://github.com/erickythierry/ipv6-multiple-proxy-server
PROXY_V6 = # sem a porta no fim!
PROXY_V6_PORT_START = 
PROXY_V6_PORT_END = 

# Pasta onde os arquivos baixados são salvos
DOWNLOAD_DIR=downloads

# Minutos até remover arquivos antigos (default: 5)
CLEANUP_MAX_AGE_MINUTES=5

# Porta do servidor (default: 5000)
PORT=5000

# Opcional: agendar exclusão do arquivo N segundos após o download (estilo Pinterest)
# AUTO_EXPIRE_SECONDS=40

# Deno + EJS para js_runtimes do yt-dlp (igual ao repo yt-dlp). Default: 1. Use 0 se rodar sem Deno.
# YTDLP_USE_EJS=1
